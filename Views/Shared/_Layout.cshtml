<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Practica_1</title>
    <style>
        :root {
            color-scheme: light;
            --bg: #f3f4f6;
            --surface: #ffffff;
            --surface-soft: #f8fafc;
            --text: #0f172a;
            --muted: #64748b;
            --border: #e2e8f0;
            --primary: #2563eb;
            --primary-soft: #dbeafe;
            --success: #16a34a;
            --danger: #dc2626;
            --radius: 24px;
            --shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
        }
        * {
            box-sizing: border-box;
        }
        html, body {
            margin: 0;
            min-height: 100%;
        }
        body {
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
        }
        a {
            color: inherit;
            text-decoration: none;
        }
        header {
            background: #ffffff;
            border-bottom: 1px solid var(--border);
        }
        .layout-header {
            max-width: 1180px;
            margin: 0 auto;
            padding: 20px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .brand-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            background: linear-gradient(135deg, #fb923c 0%, #f97316 100%);
            display: grid;
            place-items: center;
            font-weight: 700;
            color: #ffffff;
            font-size: 1rem;
        }
        .brand-title {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .brand-title strong {
            font-size: 1.05rem;
            letter-spacing: -0.03em;
        }
        .brand-title span {
            font-size: 0.85rem;
            color: var(--muted);
        }
        .nav-links {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            padding: 10px 14px;
            background: var(--surface-soft);
            border: 1px solid var(--border);
            border-radius: 999px;
        }
        .nav-links a {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 18px;
            border-radius: 999px;
            color: var(--muted);
            font-size: 0.95rem;
            font-weight: 600;
            transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
        }
        .nav-links a:hover {
            background: var(--surface-soft);
            color: var(--text);
            transform: translateY(-1px);
        }
        .nav-links a.active {
            background: var(--primary);
            color: #ffffff;
            box-shadow: 0 12px 24px rgba(37, 99, 235, 0.16);
        }
        .content {
            max-width: 1180px;
            margin: 28px auto 0;
            padding: 0 24px 40px;
        }
        main {
            min-height: calc(100vh - 180px);
        }
        footer {
            background: #ffffff;
            border-top: 1px solid var(--border);
        }
        .layout-footer {
            max-width: 1180px;
            margin: 0 auto;
            padding: 20px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            color: var(--muted);
            font-size: 0.95rem;
        }
        .layout-footer a {
            color: var(--primary);
        }
        .layout-footer a:hover {
            text-decoration: underline;
        }
        .page-header {
            display: flex;
            flex-wrap: wrap;
            align-items: flex-end;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 24px;
        }
        .page-title {
            margin: 0;
        }
        .page-title h1 {
            margin: 0;
            font-size: clamp(1.9rem, 2.3vw, 2.5rem);
            letter-spacing: -0.04em;
        }
        .page-title p {
            margin: 10px 0 0;
            color: var(--muted);
            font-size: 0.96rem;
        }
        .toolbar {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }
        .button,
        .button-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border-radius: 999px;
            padding: 11px 18px;
            font-size: 0.95rem;
            font-weight: 700;
            border: 1px solid transparent;
            cursor: pointer;
            background: var(--surface);
            color: var(--text);
            transition: all 0.2s ease;
        }
        .button.primary,
        .button-link.primary {
            background: var(--primary);
            color: #ffffff;
        }
        .button:hover,
        .button-link:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 28px rgba(15, 23, 42, 0.12);
        }
        .card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            padding: 24px;
        }
        .card-small {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            margin-bottom: 24px;
        }
        .summary-grid {
            display: grid;
            gap: 20px;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            margin-bottom: 24px;
        }
        .metric-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 28px 24px;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .metric-card h2 {
            margin: 0;
            font-size: 2.4rem;
            letter-spacing: -0.05em;
        }
        .metric-card p {
            margin: 0;
            color: var(--muted);
            font-size: 0.95rem;
        }
        .channel-grid {
            display: grid;
            gap: 16px;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }
        .channel-card {
            background: var(--surface-soft);
            border-radius: 20px;
            padding: 20px;
            border: 1px solid var(--border);
        }
        .channel-card strong {
            display: block;
            color: var(--muted);
            margin-bottom: 10px;
        }
        .channel-card span {
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--text);
        }
        .summary-action {
            margin-top: 20px;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }
        .summary-header {
            margin-bottom: 20px;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: flex-end;
            gap: 20px;
        }
        .campaign-card {
            display: flex;
            flex-direction: column;
            gap: 18px;
            border-radius: var(--radius);
            border: 1px solid var(--border);
            background: var(--surface);
            padding: 20px;
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.06);
        }
        .campaign-card .top-row {
            display: flex;
            justify-content: space-between;
            gap: 12px;
        }
        .label-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 999px;
            background: var(--surface-soft);
            color: var(--muted);
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        .status-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
        }
        .status-pill.vigente {
            background: #dcfce7;
            color: #166534;
        }
        .status-pill.proxima {
            background: #e0f2fe;
            color: #0c4a6e;
        }
        .status-pill.finalizada {
            background: #fee2e2;
            color: #991b1b;
        }
        .campaign-card h2 {
            margin: 0;
            font-size: 1.15rem;
            line-height: 1.4;
        }
        .campaign-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            color: var(--muted);
            font-size: 0.92rem;
        }
        .campaign-meta span {
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .campaign-actions {
            margin-top: auto;
        }
        .campaign-actions .button {
            width: 100%;
        }
        .detail-grid {
            display: grid;
            gap: 18px;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            margin-top: 20px;
        }
        .detail-item {
            background: var(--surface-soft);
            border-radius: 18px;
            padding: 18px;
            border: 1px solid var(--border);
        }
        .detail-item strong {
            display: block;
            margin-bottom: 10px;
            font-size: 0.9rem;
            color: var(--muted);
        }
        .detail-item span {
            font-size: 1rem;
            color: var(--text);
        }
    </style>
</head>
<body>
    @{ 
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        string NavActive(string controller, string action) =>
            string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase)
                ? "active"
                : string.Empty;
    }
    <header>
        <div class="layout-header">
            <div class="brand">
                <div class="brand-icon">RC</div>
                <div class="brand-title">
                    <strong>RetailCam</strong>
                    <span>Panel de campañas</span>
                </div>
            </div>
            <nav class="nav-links">
                <a asp-area="" asp-controller="Campanas" asp-action="Index" class="@(NavActive("Campanas", "Index"))">Listado</a>
                <a asp-area="" asp-controller="Campanas" asp-action="Resumen" class="@(NavActive("Campanas", "Resumen"))">Resumen</a>
            </nav>
        </div>
    </header>
    <div class="content">
        @RenderBody()
    </div>
    <footer>
        <div class="layout-footer">
            <span>© 2026 RetailCam</span>
            <span><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a></span>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
